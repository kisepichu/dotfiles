{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

if command -v mise >/dev/null 2>&1; then
  exit 0
fi

mise_version="{{ .miseBootstrap.version }}"
installer="$(mktemp)"
trap 'rm -f "$installer"' EXIT
curl -fsSL https://mise.run -o "$installer"
MISE_VERSION="$mise_version" sh "$installer"
{{- else -}}
#!/usr/bin/env bash
set -euo pipefail
exit 0
{{- end }}
