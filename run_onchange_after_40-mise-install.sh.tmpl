#!/usr/bin/env bash
set -euo pipefail
# dot_config/mise/config.toml checksum: {{ include "dot_config/mise/config.toml" | sha256sum }}

export PATH="$HOME/.local/bin:$PATH"

if ! command -v mise >/dev/null 2>&1; then
  echo "mise is not installed; skipping mise install" >&2
  exit 0
fi

mise install --yes
