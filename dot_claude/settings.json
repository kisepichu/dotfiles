{
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(python3 ~/.claude/skills/*/scripts/*:*)",
      "Bash(bash ~/.claude/skills/*/scripts/*:*)"
    ],
    "ask": [
      "AskUserQuestion"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/supervisor/permission-supervisor.py\"",
            "timeout": 600
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/supervisor/permission-supervisor.py\"",
            "timeout": 600
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/supervisor/permission-supervisor.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "theme": "dark",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
